# ── Lea — Evidence → Takedown · configuration ──────────────────────────────
# Copy to `.env` and fill in. Everything except GEMINI_API_KEY has a safe default.

# Server
PORT=8787

# ── AI brain (required for real classification + notice drafting) ──────────
# Google AI Studio key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Vault encryption ───────────────────────────────────────────────────────
# 32-byte hex key used to AES-256-GCM encrypt sealed content at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If left blank a key is generated on first boot and written to .vault-key (dev only).
VAULT_KEY=

# Ed25519 attestation signing key (PKCS8 PEM, base64). Auto-generated to
# .attestation-key on first boot if blank. This is what makes seals tamper-evident.
ATTESTATION_KEY=

# ── Filing (step 5) — real email delivery of the takedown notice ───────────
# Pre-set for Gmail. Filing stays in "dry-run" (drafted + sealed, nothing sent)
# until SMTP_USER and SMTP_PASS are both filled. SMTP_PASS is a Gmail App
# Password (16 chars, spaces removed) — needs 2-Step Verification enabled.
# Create one at: https://myaccount.google.com/apppasswords
# Verify the creds any time with:  GET /api/smtp/verify
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lea Takedown <your.name@gmail.com>"
# Optional: where a copy of every filing is BCC'd for the survivor's records.
FILING_BCC=

# ── Social connect (step 1) — real OAuth 2.0 authorization-code flow ───────
# Register an app at https://developers.facebook.com to get these.
# Leave blank to use "session mode" (import a browser session for logged-in capture).
META_CLIENT_ID=
META_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8787
